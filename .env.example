# Copy to .env and fill the REQUIRED values. compose.prod.yaml reads this.
# See docs/operations/running-the-daemon.md for the full walkthrough.

# ─── Chain RPC (Arbitrum One mainnet) ────────────────────────────────────
# Read-write JSON-RPC endpoint. The receiver-mode daemon needs write
# access to submit ticket-redemption transactions.
# Public endpoint works for low-volume:    https://arb1.arbitrum.io/rpc
# Provider endpoints (recommended):        https://arb-mainnet.g.alchemy.com/v2/<KEY>
#                                          https://arbitrum-mainnet.infura.io/v3/<KEY>
CHAIN_RPC=REQUIRED-https://arb1.arbitrum.io/rpc-or-your-provider

# ─── Recipient keystore (V3 JSON, encrypted) ─────────────────────────────
# The address that receives tickets. Must match the
# `operator_address` value in worker.yaml.
# Generate with: geth account new --keystore .
# Mount the JSON file + a separate file containing the password.
RECIPIENT_KEYSTORE_PATH=./keystore.json
RECIPIENT_KEYSTORE_PASSWORD_PATH=./keystore-password

# ─── Worker.yaml + presets paths on the host ─────────────────────────────
# Single source of truth for capabilities + prices + recipient address.
# All three services bind-mount worker.yaml read-only.
WORKER_YAML_PATH=./worker.yaml
PRESETS_PATH=./presets
# Container path to the preset catalogue the worker should load.
# Default unified preset catalogue for one worker serving VOD + ABR + live.
PRESETS_FILE=/etc/livepeer/presets/h264-streaming.yaml

# ─── Worker runtime mode ─────────────────────────────────────────────────
# Unified worker process by default. Override only for focused bring-up or
# debugging of a single runner.
WORKER_MODE=all

# ─── GPU vendor (drives the image tag in compose.prod.yaml) ──────────────
# nvidia | intel | amd. Live mode is NVIDIA-only at MVP.
GPU_VENDOR=nvidia
WORKER_TAG=latest

# ─── Host-side ports published for the worker ────────────────────────────
WORKER_HOST_PORT=8081
RTMP_HOST_PORT=1935

# ─── Logging ─────────────────────────────────────────────────────────────
# error | warn | info | debug
DAEMON_LOG_LEVEL=info
REGISTRY_LOG_LEVEL=info
WORKER_LOG_LEVEL=info

# ─── Metrics (Prometheus /metrics, off by default) ───────────────────────
# Set to e.g. 9091 to enable the metrics listener inside the worker
# container. Bind/publish lives in compose.prod.yaml — uncomment that
# block once this is set.
# METRICS_PORT=9091

# ─── Daemon image tag pins ───────────────────────────────────────────────
# Pin daemon versions to a known-good release. Defaults are reasonable
# but pin in production for reproducibility.
PAYMENT_DAEMON_TAG=v4.0.1
REGISTRY_DAEMON_TAG=v1.2.0
